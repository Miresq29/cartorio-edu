rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    function isActiveUser() {
      return request.auth != null && userDoc().active == true;
    }
    function myTenant() { return userDoc().tenantId; }
    function isSuperAdmin() { return isActiveUser() && userDoc().role == 'SUPERADMIN'; }
    function isGestor() { return isActiveUser() && userDoc().role in ['SUPERADMIN', 'gestor', 'admin']; }

    // Materiais de banner — gestores do próprio tenant escrevem, mesmo tenant (ou conteúdo GLOBAL) lê
    match /materiais/{tenantId}/{allPaths=**} {
      allow read:  if isSuperAdmin() || (isActiveUser() && (myTenant() == tenantId || tenantId == 'GLOBAL'));
      allow write: if isSuperAdmin() || (isGestor() && myTenant() == tenantId);
    }

    // Deny-all fallback
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
