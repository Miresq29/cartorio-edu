rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Materiais de banner — gestores podem escrever, autenticados podem ler
    match /materiais/{tenantId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deny-all fallback
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
