// --- modo checklist ---
if (kbDocs.length > 0) {
  contextBlock = kbDocs
    .slice(0, 3) // âœ… mÃ¡ximo 3 documentos de base legal
    .map((d: any, i: number) =>
      `[DOCUMENTO BASE LEGAL ${i + 1} â€” ${d.fileName}]\n${(d.rawText || d.content)?.substring(0, 1500)}` // âœ… era 2000
    ).join('\n\n---\n\n');
}

