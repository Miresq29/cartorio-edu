rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return isAuthenticated() && getUserData().get('active', false) == true;
    }

    function isGestor() {
      return isActive() && getUserData().get('role', '') in ['SUPERADMIN', 'gestor', 'admin'];
    }

    function isSuperAdmin() {
      return isActive() && getUserData().get('role', '') == 'SUPERADMIN';
    }

    // Acesso público necessário (pré-autenticação)
    match /loginAttempts/{docId} {
      allow read, write: if true;
    }

    match /auditLogs/{docId} {
      allow read: if isGestor();
      allow create: if true;
      allow update, delete: if false;
    }

    // Usuários
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Treinamentos
    match /treinamentos/{docId} {
      allow read: if isActive();
      allow create, update, delete: if isGestor();
    }

    match /treinamentosQuizzes/{docId} {
      allow read: if isActive();
      allow create, update, delete: if isGestor();
    }

    match /treinamentosQuizResults/{docId} {
      allow read: if isActive();
      allow create, update: if isActive();
      allow delete: if isGestor();
    }

    match /treinamentosParticipantes/{docId} {
      allow read: if isActive();
      allow create, update: if isActive();
      allow delete: if isGestor();
    }

    // Trilhas
    match /trilhas/{docId} {
      allow read: if isActive();
      allow create, update, delete: if isGestor();
    }

    match /trilhasProgresso/{docId} {
      allow read: if isActive();
      allow create, update: if isActive();
      allow delete: if isGestor();
    }

    // Base de conhecimento e checklists
    match /knowledgeBase/{docId} {
      allow read: if isActive();
      allow create, update: if isGestor();
      allow delete: if isGestor();
    }

    match /checklists/{docId} {
      allow read: if isActive();
      allow create, update: if isGestor();
      allow delete: if isGestor();
    }

    // Vídeos de treinamento
    match /videos/{docId} {
      allow read: if isActive();
      allow create, update, delete: if isGestor();
    }

    match /videosProgresso/{docId} {
      allow read: if isActive();
      allow create, update: if isActive();
      allow delete: if isGestor();
    }

    // Comunicados
    match /comunicados/{docId} {
      allow read: if isActive();
      allow create, update, delete: if isGestor();
    }

    match /comunicadosLeituras/{docId} {
      allow read: if isActive();
      allow create, update: if isActive();
      allow delete: if isGestor();
    }

    // Banners e materiais
    match /materiaisbanner/{docId} {
      allow read: if isActive();
      allow create, update: if isGestor();
      allow delete: if isGestor();
    }

    // Exames
    match /examesResultados/{docId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update, delete: if isGestor();
    }

    // Cartorios / tenants
    match /cartorios/{docId} {
      allow read: if isActive();
      allow write: if isSuperAdmin();
    }

    // Deny-all fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
