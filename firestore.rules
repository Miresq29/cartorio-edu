rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function userExists() { return exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isActive() { return isAuthenticated() && userExists() && getUserData().get('active', false) == true; }
    function isSuperAdmin() { return isActive() && getUserData().get('role', '') == 'SUPERADMIN'; }
    function isGestor() { return isActive() && getUserData().get('role', '') in ['SUPERADMIN', 'gestor', 'admin']; }

    // Tenant isolation helpers
    function myTenant() { return getUserData().get('tenantId', ''); }
    function sameTenant() { return resource.data.get('tenantId', myTenant()) == myTenant(); }
    function newSameTenant() { return request.resource.data.get('tenantId', myTenant()) == myTenant(); }
    function tenantUnchanged() { return request.resource.data.get('tenantId', '') == resource.data.get('tenantId', ''); }
    function isGlobalContent() { return resource.data.get('tenantId', '') == 'GLOBAL'; }
    function isSelfData() { return request.resource.data.get('userId', '') == request.auth.uid; }

    // Content: SUPERADMIN vê tudo; demais usuários: mesmo tenant ou global
    function canReadContent() { return isSuperAdmin() || (isActive() && (sameTenant() || isGlobalContent())); }
    function canWriteContent() { return isSuperAdmin() || (isGestor() && newSameTenant()); }
    function canEditContent() { return isSuperAdmin() || (isGestor() && sameTenant() && tenantUnchanged()); }

    // Private: strictly per tenant, SUPERADMIN sees all
    function canReadPrivate() { return isSuperAdmin() || (isActive() && sameTenant()); }
    function canWritePrivate() { return isActive() && newSameTenant(); }
    function canEditPrivate() { return isSuperAdmin() || (isGestor() && sameTenant()); }
    // Private + dono do registro: usar nas coleções onde o campo userId reflete o uid autenticado
    function canWriteOwnPrivate() { return canWritePrivate() && (isSelfData() || isGestor()); }

    match /users/{userId} {
      allow read: if isSuperAdmin()
        || request.auth.uid == userId
        || (isActive() && resource.data.get('tenantId', '') == myTenant());
      allow create: if isSuperAdmin() || (isGestor() && newSameTenant());
      allow update: if isSuperAdmin()
        || (isGestor() && sameTenant() && tenantUnchanged()
            && request.resource.data.get('role', '') == resource.data.get('role', ''));
      allow delete: if isSuperAdmin();
    }

    // Fluxo de login roda sem sessao Firebase Auth ainda (nao da pra exigir isAuthenticated aqui).
    // Restringe o formato do documento para impedir bloqueio arbitrario/indefinido de contas alheias.
    match /loginAttempts/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['attempts', 'lastAttempt'])
                    && request.resource.data.attempts == 1;
      allow update: if request.resource.data.keys().hasOnly(['attempts', 'lastAttempt', 'lockedUntil'])
                    && request.resource.data.attempts is int
                    && request.resource.data.attempts >= 0
                    && request.resource.data.attempts <= resource.data.get('attempts', 0) + 1
                    && (!('lockedUntil' in request.resource.data)
                        || request.resource.data.lockedUntil == null
                        || request.resource.data.lockedUntil <= request.time + duration.value(5, 'm'));
    }

    match /auditLogs/{docId} {
      allow read: if isSuperAdmin() || (isGestor() && sameTenant());
      // Autenticado: so pode registrar acao em nome de si mesmo (evita forjar log de outro usuario).
      // Nao autenticado: so o evento de login falho, sem severidade CRITICAL (evita poluir/forjar auditoria).
      allow create: if (isAuthenticated() && request.resource.data.get('usuarioId', '') == request.auth.uid)
                    || (!isAuthenticated()
                        && request.resource.data.get('tipo', '') == 'LOGIN_FAILED'
                        && request.resource.data.get('severity', 'INFO') != 'CRITICAL');
    }

    // ── Conteúdo compartilhável (tenantId == 'GLOBAL' = visível a todos) ──

    match /treinamentos/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /treinamentosQuizzes/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /trilhas/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /knowledgeBase/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /checklists/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /videos/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /materiaisbanner/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /comunicados/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /repositorio/{docId} {
      allow read: if canReadContent();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }

    // ── Dados privados (estritamente por cartório) ──

    match /treinamentosQuizResults/{docId} {
      allow read: if canReadPrivate();
      allow create: if canWritePrivate();
      allow update: if canEditPrivate();
      allow delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /trilhasProgresso/{docId} {
      allow read: if canReadPrivate();
      allow create, update: if canWriteOwnPrivate();
      allow delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /treinamentosParticipantes/{docId} {
      allow read: if canReadPrivate();
      allow create, update: if canWritePrivate();
      allow delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /videosProgresso/{docId} {
      allow read: if canReadPrivate();
      allow create, update: if canWriteOwnPrivate();
      allow delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /comunicadosLeituras/{docId} {
      allow read: if canReadPrivate();
      allow create, update: if canWriteOwnPrivate();
      allow delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /examesResultados/{docId} {
      allow read: if canReadPrivate();
      allow create: if canWriteOwnPrivate();
      allow update, delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /metas/{docId} {
      allow read: if canReadPrivate();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /metasDesempate/{docId} {
      allow read: if canReadPrivate();
      allow create: if canWriteContent();
      allow update, delete: if canEditContent();
    }
    match /repositorioProgresso/{docId} {
      allow read: if canReadPrivate();
      allow create, update: if canWriteOwnPrivate();
      allow delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /certificados/{docId} {
      allow read: if canReadPrivate();
      // Emissao de certificado exige gestor/admin — evita autoemissao de aprovacao sem concluir o treinamento
      allow create: if isSuperAdmin() || (isGestor() && newSameTenant());
      allow update: if isSuperAdmin() || (isGestor() && sameTenant() && tenantUnchanged());
      allow delete: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /resumos/{docId} {
      allow read: if canReadPrivate();
      allow create: if canWritePrivate();
      allow update, delete: if canEditPrivate();
    }
    match /backup/{docId} {
      allow read, write: if isSuperAdmin() || (isGestor() && sameTenant());
    }
    match /cartorios/{docId} {
      allow read: if isActive();
      allow write: if isSuperAdmin();
    }
    match /tenants/{docId} {
      // TODO(seguranca): varias telas (TenantsView, DashboardMasterView, dropdown em UsersView)
      // fazem list() sem filtro nessa colecao — confirmar que sao SUPERADMIN-only antes de
      // restringir por tenant, senao quebra essas telas para gestores comuns.
      allow read: if isActive();
      allow write: if isSuperAdmin();
    }

    match /{document=**} { allow read, write: if false; }
  }
}
